<%- layout("layouts/boilerplate") %>

<section class="diseases-page">

    <div class="container">

        <!-- Heading -->

        <div class="page-heading text-center">

            <h1>
                🩺 Diseases & Natural Remedies
            </h1>

            <p>
                Explore common health conditions and discover medicinal plants
                traditionally used in Ayurveda and other AYUSH systems.
            </p>

        </div>

        <!-- Add Disease Button -->

        <% if(currUser){ %>

            <div class="text-end mb-4">

                <a href="/diseases/new" class="btn btn-success">

                    <i class="fa-solid fa-plus"></i>

                    Add New Disease

                </a>

            </div>

        <% } %>

        <!-- Disease Cards -->

        <div class="row g-4">

            <% for(let disease of allDiseases){ %>

            <div class="col-lg-4 col-md-6">

                <div class="card disease-index-card h-100">

                    <div class="card-body">

                        <div class="text-center">

                            <i class="fa-solid fa-notes-medical disease-icon"></i>

                            <h3 class="mt-3">

                                <%= disease.name %>

                            </h3>

                        </div>

                        <hr>

                        <p>

                            <strong>Category:</strong>

                            <span class="badge bg-success">

                                <%= disease.category %>

                            </span>

                        </p>

                        <p>

                            <strong>Symptoms:</strong>

                            <%= disease.symptoms.slice(0,3).join(", ") %>

                        </p>

                        <p>

                            <strong>Recommended Plants:</strong>

                            <%= disease.recommendedPlants.length %>

                        </p>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <a
                            href="/diseases/<%= disease._id %>"
                            class="btn btn-success w-100"
                        >

                            View Details

                        </a>

                    </div>

                </div>

            </div>

            <% } %>

        </div>

    </div>

</section>