<%- layout("layouts/boilerplate") %>

<section class="show-disease-section">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-10">

                <div class="card border-0 shadow-lg rounded-4">

                    <div class="card-body p-5">

                        <!-- Disease Title -->

                        <div class="text-center mb-5">

    <img
        src="<%= disease.image?.url || '/images/default-disease.jpg' %>"
        class="show-image mb-4"
        alt="<%= disease.diseaseName %>"
    >

    <h1 class="mt-3">

        <%= disease.diseaseName %>

    </h1>

</div>

                        <!-- Description -->

                        <h3 class="section-heading">
                            📖 Description
                        </h3>

                        <p>
                            <%= disease.description %>
                        </p>

                        <hr>

                        <!-- Symptoms -->

                        <h3 class="section-heading">
                            🤒 Symptoms
                        </h3>

                        <ul>

                            <% if(disease.symptoms.length){ %>

                                <% disease.symptoms.forEach(symptom => { %>

                                    <li><%= symptom %></li>

                                <% }) %>

                            <% } else { %>

                                <li>No symptoms added.</li>

                            <% } %>

                        </ul>

                        <hr>

                        <!-- Recommended Plants -->

                        <h3 class="section-heading">
                            🌿 Recommended Medicinal Plants
                        </h3>

                        <% if(disease.recommendedPlants.length){ %>

                            <div class="row">

                                <% disease.recommendedPlants.forEach(plant => { %>

                                    <div class="col-md-4 mb-3">

                                        <div class="card h-100">

                                            <div class="card-body text-center">

                                                <h5>

                                                    <%= plant.commonName %>

                                                </h5>

                                                <p class="text-muted">

                                                    <%= plant.scientificName %>

                                                </p>

                                                <a
                                                    href="/plants/<%= plant._id %>"
                                                    class="btn btn-success btn-sm"
                                                >
                                                    View Plant
                                                </a>

                                            </div>

                                        </div>

                                    </div>

                                <% }) %>

                            </div>

                        <% } else { %>

                            <p class="text-muted">

                                No medicinal plants linked yet.

                            </p>

                        <% } %>

                        <hr>

                        <!-- Disclaimer -->

                        <div class="alert alert-warning">

                            <strong>Medical Disclaimer:</strong>

                            This information is for educational purposes only.
                            Consult a qualified healthcare professional before
                            using herbal remedies.

                        </div>

                        <% if(currUser){ %>

                        <div class="mt-4">

                            <a
                                href="/diseases/<%= disease._id %>/edit"
                                class="btn btn-warning me-2"
                            >
                                <i class="fa-solid fa-pen-to-square"></i>
                                Edit
                            </a>

                            <form
                                action="/diseases/<%= disease._id %>?_method=DELETE"
                                method="POST"
                                class="d-inline"
                            >

                                <button class="btn btn-danger">

                                    <i class="fa-solid fa-trash"></i>

                                    Delete

                                </button>

                            </form>

                        </div>

                        <% } %>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>