<%- layout("layouts/boilerplate") %>
<section class="show-plant-section py-5">
    <div class="container">
        <div class="row">
            <!-- Left Side -->
            <div class="col-lg-5">
                <img
                    src="<%= plant.image && plant.image.url ? plant.image.url : '/images/default-plant.jpg' %>"
                    class="img-fluid show-image rounded-4 shadow"
                    alt="<%= plant.commonName %>"
                >
            </div>
            <!-- Right Side -->
            <div class="col-lg-7">
                <h1 class="show-title">
                    <%= plant.commonName %>
                </h1>
                <h4 class="text-muted mb-4">
                    <em><%= plant.scientificName %></em>
                </h4>
                <table class="table table-bordered">
                    <tr>
                        <th>Local Name</th>
                        <td><%= plant.localName %></td>
                    </tr>
                    <tr>
                        <th>Plant Type</th>
                        <td><%= plant.plantType %></td>
                    </tr>
                    <tr>
                        <th>AYUSH System</th>
                        <td><%= plant.ayushSystem %></td>
                    </tr>
                    <tr>
                        <th>Parts Used</th>
                        <td>
                            <% plant.partsUsed.forEach(part => { %>
                                <span class="badge bg-success me-2">
                                    <%= part %>
                                </span>
                            <% }) %>
                        </td>
                    </tr>
                </table>
                <hr>
                <h3>🌿 Primary Uses</h3>
                <ul>
                    <% plant.medicinalUses.primaryUses.forEach(use => { %>
                        <li><%= use %></li>
                    <% }) %>
                </ul>
                <hr>
                <h3>🩺 Conditions Treated</h3>
                <ul>
                    <% plant.medicinalUses.conditionsTreated.forEach(condition => { %>
                        <li><%= condition %></li>
                    <% }) %>
                </ul>
                <hr>
                <!-- Related Diseases -->
                <h3 class="mb-4">
                    🦠 Related Diseases
                </h3>
                <% if(diseases && diseases.length){ %>
                <div class="row">
                    <% diseases.forEach(disease => { %>
                    <div class="col-md-6 mb-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4">
                            <img
                                src="<%= disease.image.url %>"
                                class="card-img-top"
                                style="height:180px; object-fit:cover;"
                                alt="<%= disease.diseaseName %>"
                            >
                            <div class="card-body">
                                <h5>
                                    <%= disease.diseaseName %>
                                </h5>
                                <p class="text-muted">
                                    <%= disease.description.substring(0,100) %>...
                                </p>
                                <a
                                    href="/diseases/<%= disease._id %>"
                                    class="btn btn-success w-100"
                                >
                                    View Disease
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="alert alert-secondary">
                    No diseases linked with this medicinal plant.
                </div>
                <% } %>
                <hr>
                <h3>🧪 How To Use</h3>
                <h5>
                    Method :
                    <span class="text-success">
                        <%= plant.howToUse.method %>
                    </span>
                </h5>
                <ol>
                    <% plant.howToUse.steps.forEach(step => { %>
                        <li><%= step %></li>
                    <% }) %>
                </ol>
                <hr>
                <h3>⚠ Precautions</h3>
                <ul>
                    <% plant.precautions.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
                <hr>
                <h3>💊 Possible Side Effects</h3>
                <h5>Mild</h5>
                <ul>
                    <% plant.possibleSideEffects.mild.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
                <h5>Overuse</h5>
                <ul>
                    <% plant.possibleSideEffects.overuse.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
                <h5>Allergic Reactions</h5>
                <ul>
                    <% plant.possibleSideEffects.allergicReactions.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
                <hr>
                <% if(currUser && currUser.role === "admin"){ %>
                <a
                    href="/plants/<%= plant._id %>/edit"
                    class="btn btn-warning me-3"
                >
                    Edit
                </a>
                <form
                    method="POST"
                    action="/plants/<%= plant._id %>?_method=DELETE"
                    class="d-inline"
                >
                    <button class="btn btn-danger">
                        Delete
                    </button>
                </form>
                <% } %>
            </div>
        </div>
    </div>
</section>