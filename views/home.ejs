<%- layout("layouts/boilerplate") %>
<!-- ================= HERO SECTION ================= -->
<section class="hero-section">
    <div class="container text-center">
        <!-- Heading -->
        <h1 class="hero-title">
            Explore India's
            <span>Medicinal Plant Heritage</span>
        </h1>
        <p class="hero-tagline">
            Virtual Herbal Garden
        </p>
        <!-- Hero Content -->
<div class="hero-content">
    <!-- Left Side -->
    <div class="hero-left">
        <img
            src="/images/hero.png"
            class="hero-image"
            alt="Virtual Herbal Garden">
    </div>
    <!-- Right Side -->
    <div class="hero-right">
        <div class="hero-feature">
            <i class="fa-solid fa-flask-vial"></i>
            <span>Scientific Information</span>
        </div>
        <div class="hero-feature">
            <i class="fa-solid fa-shield-heart"></i>
            <span>Safe Usage Guidelines</span>
        </div>
        <div class="hero-feature">
            <i class="fa-solid fa-magnifying-glass"></i>
            <span>Smart Search</span>
        </div>
        <div class="hero-feature">
            <i class="fa-solid fa-heart-pulse"></i>
            <span>Disease-wise Remedies</span>
        </div>
    </div>
</div><!-- Description -->
        <p class="hero-subtitle mx-auto">
            Discover the healing power of nature through India's rich
            medicinal plant heritage.

            Learn scientific names, medicinal uses, preparation methods,
            precautions, side effects, and disease-wise herbal remedies
            from one comprehensive digital platform.
        </p>
        <!-- Buttons -->
        <div class="hero-buttons">
            <a href="/plants" class="btn btn-success btn-lg me-3">
                <i class="fa-solid fa-seedling"></i>
                Explore Plants
            </a>
            <a href="/diseases"
               class="btn btn-outline-success btn-lg">
                <i class="fa-solid fa-notes-medical"></i>
                Explore Diseases
            </a>
        </div>
    </div>
</section>
<!-- ================= STATISTICS ================= --><!-- ================= STATISTICS ================= -->
<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            <!-- Medicinal Plants -->
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fa-solid fa-seedling"></i>
                    <h2
                        class="counter"
                        data-target="<%= totalPlants %>"
                        data-plus="true"
                    >
                        0
                    </h2>
                    <p>Medicinal Plants</p>
                </div>
            </div>
            <!-- Diseases -->
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fa-solid fa-notes-medical"></i>
                    <h2
                        class="counter"
                        data-target="<%= totalDiseases %>"
                        data-plus="true"
                    >
                        0
                    </h2>
                    <p>Diseases</p>
                </div>
            </div>
            <!-- Plant Categories -->
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fa-solid fa-leaf"></i>
                    <h2
                        class="counter"
                        data-target="<%= totalCategories %>"
                        data-plus="false"
                    >
                        0
                    </h2>
                    <p>Plant Categories</p>
                </div>
            </div>
            <!-- AYUSH Systems -->
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fa-solid fa-heart-pulse"></i>
                    <h2
                        class="counter"
                        data-target="<%= totalAyushSystems %>"
                        data-plus="false"
                    >
                        0
                    </h2>
                    <p>AYUSH Systems</p>
                </div>
            </div>
        </div>
    </div>
</section>
            <!-- ================= FEATURED PLANTS ================= -->
<section class="featured-section">
    <div class="container">
        <h2 class="section-title">
            Featured Medicinal Plants
        </h2>
        <div class="row g-4">
            <% if(featuredPlants && featuredPlants.length){ %>
                <% featuredPlants.forEach(plant => { %>
                    <div class="col-lg-3 col-md-6">
                        <div class="plant-card h-100">
                            <img
                                src="<%= plant.image.url %>"
                                class="card-img-top"
                                alt="<%= plant.commonName %>"
                            >
                            <div class="card-body text-center">
                                <h5>
                                    <%= plant.commonName %>
                                </h5>
                                <p class="text-muted">
                                    <em>
                                        <%= plant.scientificName %>
                                    </em>
                                </p>
                                <span class="badge bg-success mb-3">
                                    <%= plant.plantType %>
                                </span>
                                <br>
                                <a
                                    href="/plants/<%= plant._id %>"
                                    class="btn btn-success btn-sm"
                                >
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center">
                    <div class="alert alert-warning">
                        No featured plants available.
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</section>
<!-- ================= FEATURED DISEASES ================= -->
<section class="disease-section">
    <div class="container">
        <h2 class="section-title">
            Explore By Disease
        </h2>
        <div class="row g-4">
            <% if(featuredDiseases && featuredDiseases.length){ %>
                <% featuredDiseases.forEach(disease => { %>
                    <div class="col-lg-2 col-md-4 col-6">
                        <a
                            href="/diseases/<%= disease._id %>"
                            class="text-decoration-none"
                        >
                            <div class="disease-card h-100">
                                <img
                                    src="<%= disease.image.url %>"
                                    class="img-fluid rounded-circle mb-3"
                                    style="
                                        width:100px;
                                        height:100px;
                                        object-fit:cover;
                                    "
                                    alt="<%= disease.diseaseName %>"
                                >
                                <h5><%= disease.diseaseName %></h5>
                            </div>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-warning text-center">
                        No diseases available.
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</section>
<!-- ================= CATEGORIES ================= -->
<section class="category-section">
    <div class="container">
        <h2 class="section-title">
            Explore Plant Categories
        </h2>
        <%
            const categoryIcons = {
                Herb: "🌿",
                Tree: "🌳",
                Shrub: "🌾",
                Climber: "🌱",
                Flower: "🌺",
                Grass: "🍃"
            };
        %>
        <div class="row g-4 justify-content-center">
            <% categories.forEach(category => { %>
                <div class="col-lg-2 col-md-4 col-6">
                    <a href="/plants?plantType=<%= category %>"
                        class="text-decoration-none">
                        <div class="category-box text-center">
                            <div style="font-size:3rem;">
                                <%= categoryIcons[category] || "🌿" %>
                            </div>
                            <h5>
                                <%= category %>
                            </h5>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</section>
<!-- ================= WHY CHOOSE US ================= -->
<section class="why-section">
    <div class="container">
        <h2 class="section-title">
            Why Choose Virtual Herbal Garden?
        </h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-box">
                    <i class="fa-solid fa-book-medical"></i>
                    <h4>Scientific Information</h4>
                    <p>
                        Every medicinal plant includes its scientific name,
                        medicinal uses, precautions and side effects.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <i class="fa-solid fa-shield-heart"></i>
                    <h4>Safe Usage</h4>
                    <p>
                        Learn proper preparation methods, dosage guidance,
                        precautions and situations where herbs should not be
                        used.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <h4>Smart Search</h4>
                    <p>
                        Search medicinal plants by their common name,
                        scientific name or diseases they help manage.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ================= FAQ ================= -->
<section class="faq-section">
    <div class="container">
        <h2 class="section-title">
            Frequently Asked Questions
        </h2>
        <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button
                        class="accordion-button"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#faq1">
                        What is a Virtual Herbal Garden?
                    </button>
                </h2>
                <div id="faq1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        A digital platform that provides complete
                        information about medicinal plants including
                        scientific names, medicinal uses, preparation
                        methods, precautions and side effects.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button
                        class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#faq2">
                        Can I search plants by disease?
                    </button>
                </h2>
                <div id="faq2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Yes. The project allows searching medicinal
                        plants that may traditionally be associated
                        with particular health conditions.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button
                        class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#faq3">
                        Are herbal remedies a replacement for doctors?
                    </button>
                </h2>
                <div id="faq3" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        No. The information is provided for educational
                        purposes only. Users should consult qualified
                        healthcare professionals before starting any
                        treatment.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ================= CALL TO ACTION ================= -->
<section class="cta-section">
    <div class="container text-center">
        <h2>Start Exploring Nature's Pharmacy</h2>
        <p>
            Browse medicinal plants, discover natural remedies,
            and learn how traditional herbs contribute to a healthier lifestyle.
        </p>
        <a href="/plants" class="btn btn-light btn-lg me-3">
            <i class="fa-solid fa-seedling"></i>
            Explore Plants
        </a>
        <a href="/signup" class="btn btn-outline-light btn-lg">
            <i class="fa-solid fa-user-plus"></i>
            Join Now
        </a>
    </div>
</section>
<!-- ================= ABOUT ================= -->
<section class="about-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <img
                    src="/images/about.png"
                    class="img-fluid about-image"
                    alt="About Herbal Garden"
                >
            </div>
            <div class="col-lg-6">
                <h2 class="section-title text-start">
                    About Our Project
                </h2>
                <p class="about-text">
                    Virtual Herbal Garden is a web-based platform designed
                    to preserve and promote knowledge about medicinal plants.
                </p>
                <p class="about-text">
                    Users can explore herbs, understand their medicinal
                    properties, learn safe usage methods, discover possible
                    side effects, and search plants based on diseases.
                </p>
                <p class="about-text">
                    This project encourages awareness of traditional
                    healthcare systems such as Ayurveda, Siddha, Unani and
                    other natural healing practices.
                </p>
            </div>
        </div>
    </div>
</section>