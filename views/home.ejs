        <div class="row g-4">

            <div class="col-lg-3">

                <div class="plant-card">

                    <img src="/images/tulsi.jpg" class="card-img-top">

                    <div class="card-body">

                        <h5>Tulsi</h5>

                        <p>Ocimum sanctum</p>

                    </div>

                </div>

            </div>

            <div class="col-lg-3">

                <div class="plant-card">

                    <img src="/images/neem.jpg" class="card-img-top">

                    <div class="card-body">

                        <h5>Neem</h5>

