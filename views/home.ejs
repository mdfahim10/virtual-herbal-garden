<%- layout("layouts/boilerplate") %>

<!-- ================= HERO SECTION ================= -->

<section class="hero-section">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <h1 class="hero-title">
                    🌿 Virtual Herbal Garden
                </h1>

                <p class="hero-subtitle">
                    Discover the Healing Power of Nature through India's
                    traditional medicinal plants. Learn their scientific
                    names, medicinal uses, preparation methods, precautions,
                    and possible side effects.
                </p>

                <div class="hero-buttons">

                    <a href="/plants" class="btn btn-success btn-lg me-3">
                        Explore Plants
                    </a>

                    <a href="/diseases" class="btn btn-outline-success btn-lg">
                        Explore Diseases
                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img
                    src="/images/hero.png"
                    class="img-fluid hero-image"
                    alt="Virtual Herbal Garden"
                >

            </div>

        </div>

    </div>

</section>


<!-- ================= STATISTICS ================= -->

<section class="stats-section">

    <div class="container">

        <div class="row g-4">

            <div class="col-md-3">

                <div class="stat-card">

                    <i class="fa-solid fa-seedling"></i>

                    <h2>50+</h2>

                    <p>Medicinal Plants</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <i class="fa-solid fa-notes-medical"></i>

                    <h2>20+</h2>

                    <p>Diseases</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <i class="fa-solid fa-leaf"></i>

                    <h2>6</h2>

                    <p>Plant Categories</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <i class="fa-solid fa-heart-pulse"></i>

                    <h2>100%</h2>

                    <p>Natural Remedies</p>

                </div>

            </div>

        </div>

    </div>

</section>


<!-- ================= FEATURED PLANTS ================= -->

<section class="featured-section">

