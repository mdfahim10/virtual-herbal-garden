            </div>

            <div class="col-lg-3">

                <div class="plant-card">

                    <img src="/images/aloe.jpg" class="card-img-top">

                    <div class="card-body">

                        <h5>Aloe Vera</h5>

                        <p>Aloe barbadensis</p>

                    </div>

                </div>

            </div>

            <div class="col-lg-3">

                <div class="plant-card">

                    <img src="/images/ashwagandha.jpg" class="card-img-top">

                    <div class="card-body">

                        <h5>Ashwagandha</h5>

                        <p>Withania somnifera</p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= WHY CHOOSE US ================= -->

<section class="why-section">

    <div class="container">

        <h2 class="section-title">
            Why Choose Virtual Herbal Garden?
        </h2>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="feature-box">

                    <i class="fa-solid fa-book-medical"></i>

                    <h4>Scientific Information</h4>

                    <p>
                        Every medicinal plant includes its scientific name,
                        medicinal uses, precautions and side effects.
                    </p>

